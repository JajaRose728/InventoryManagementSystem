/**
 * Firestore Security Rules
 * For development, we'll use permissive rules
 * For production, add proper authentication and role-based access
 */

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Development mode - Allow all authenticated reads/writes
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Users collection - Only authenticated users
    match /users/{uid} {
      allow read: if request.auth.uid == uid || request.auth.token.role == 'admin';
      allow write: if request.auth.uid == uid;
      allow create: if request.auth.uid == uid;
    }

    // Products collection
    match /products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth.token.role == 'admin';
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role == 'admin';
    }

    // Stock History collection
    match /stockHistory/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Activity Logs collection
    match /activityLogs/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow create: if request.auth != null;
    }
  }
}